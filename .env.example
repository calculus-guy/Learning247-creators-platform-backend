# ========================================
# Server Configuration
# ========================================
PORT=8080
JWT_SECRET_KEY=your_jwt_secret_key_here
SESSION_SECRET=your_session_secret_here

# ========================================
# Database Configuration (PostgreSQL)
# ========================================
DB_NAME=your_database_name
DB_USER=postgres
DB_PASS=your_database_password
DB_HOST=localhost
DB_PORT=5432

# ========================================
# Google OAuth Configuration
# ========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-domain.com/auth/google/callback

# ========================================
# Mux Configuration (Video Streaming)
# ========================================
MUX_SECRET_KEY=your_mux_secret_key
MUX_TOKEN_ID=your_mux_token_id
MUX_TOKEN_SECRET=your_mux_token_secret
MUX_WEBHOOK_SECRET=your_mux_webhook_secret

# ========================================
# Frontend Configuration
# ========================================
CLIENT_URL=https://your-frontend-domain.com

# ========================================
# Email Configuration
# ========================================
EMAIL_HOST=your_email_host
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your_email@domain.com
EMAIL_PASS=your_email_password

# ========================================
# Event Configuration
# ========================================
EVENT_DATE=February 12, 2026
EVENT_TIME=3:00PM

# ========================================
# Payment Gateway Configuration
# ========================================

# Paystack (Nigerian payments)
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# Stripe (International payments)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_live_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ========================================
# ZegoCloud Configuration (Live Streaming)
# ========================================
ZEGO_APP_ID=your_zego_app_id
ZEGO_SERVER_SECRET=your_zego_server_secret
ZEGO_APP_SIGN=your_zego_app_sign
ZEGO_ENVIRONMENT=production
ZEGO_TOKEN_EXPIRY=3600
ZEGO_MAX_PARTICIPANTS=200

# ========================================
# AWS Configuration (S3 Storage)
# ========================================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_s3_bucket_name

# ========================================
# Course Pricing Configuration
# ========================================

# Valentine's Promo
VALENTINE_PROMO_CODE=VALENTINE2025
VALENTINE_PROMO_END=2026-02-28T23:59:59

# Regular Pricing (NGN)
COURSE_PRICE_INDIVIDUAL_NGN=25000
COURSE_PRICE_MONTHLY_NGN=35000
COURSE_PRICE_YEARLY_NGN=280000

# Regular Pricing (USD)
COURSE_PRICE_INDIVIDUAL_USD=30
COURSE_PRICE_MONTHLY_USD=42
COURSE_PRICE_YEARLY_USD=336

# Promo Pricing (NGN)
PROMO_PRICE_INDIVIDUAL_NGN=20000
PROMO_PRICE_MONTHLY_NGN=25000
PROMO_PRICE_YEARLY_NGN=250000

# Promo Pricing (USD)
PROMO_PRICE_INDIVIDUAL_USD=24
PROMO_PRICE_MONTHLY_USD=30
PROMO_PRICE_YEARLY_USD=300

# ========================================
# Currency Conversion Configuration
# ========================================
# Fixed conversion rate: 1 USD = X NGN
CURRENCY_CONVERSION_RATE_NGN_TO_USD=1400

# ========================================
# Notification Configuration
# ========================================
# Enable/disable email notifications (set to false during testing)
NOTIFICATIONS_ENABLED=true

# ========================================
# Coupon System Configuration
# ========================================
# Partner wallet user ID for Nigerian Teachers Association
PARTNER_NIGERIAN_TEACHERS_USER_ID=your_partner_user_id

# ========================================
# Redis Configuration (for Quiz Platform)
# ========================================
# Redis connection for active users, leaderboards, and rate limiting
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========================================
# Quiz Platform Configuration
# ========================================
# Currency conversion: 1 USD = 1 Morgan = 100 Chuta
# 1 Chuta = $0.01 USD

# Initial bonus for new quiz users (in Chuta)
QUIZ_INITIAL_BONUS=100

# Withdrawal settings
QUIZ_MIN_WITHDRAWAL_CHUTA=1000
QUIZ_WITHDRAWAL_FEE_PERCENT=10

# Active user tracking
QUIZ_ACTIVE_USER_TIMEOUT=180

# Rate limiting (per user)
QUIZ_RATE_LIMIT_ANSWERS_PER_WINDOW=15
QUIZ_RATE_LIMIT_ANSWERS_WINDOW_SECONDS=10
QUIZ_RATE_LIMIT_CHALLENGES_PER_WINDOW=10
QUIZ_RATE_LIMIT_CHALLENGES_WINDOW_SECONDS=3600
QUIZ_RATE_LIMIT_TOURNAMENTS_PER_WINDOW=20
QUIZ_RATE_LIMIT_TOURNAMENTS_WINDOW_SECONDS=3600

# Match settings
QUIZ_QUESTIONS_PER_MATCH=10
QUIZ_TIME_PER_QUESTION_SECONDS=10
QUIZ_LATENCY_BUFFER_SECONDS=2

# Leaderboard cache TTL (seconds)
QUIZ_LEADERBOARD_CACHE_TTL=300

# Challenge expiration (hours)
QUIZ_CHALLENGE_EXPIRATION_HOURS=24

# Reconnection grace period (seconds)
QUIZ_RECONNECTION_GRACE_PERIOD=30

# Suspicious activity threshold (flags per 24 hours)
QUIZ_SUSPICIOUS_ACTIVITY_THRESHOLD=5
